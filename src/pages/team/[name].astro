---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import {
  Linkedin,
  Github,
  Mail,
  MapPin,
  Link2,
  Building2,
  ChevronLeft,
  FileCode,
} from "@lucide/astro";
import { Image } from "astro:assets";
import teamMembers from "../../content/team.json";
import teamLeads from "../../content/teamLead.json";

export async function getStaticPaths() {
  const allMembers = [
    ...teamMembers.map((m) => ({ ...m, type: "core" })),
    ...teamLeads.map((m) => ({ ...m, type: "lead" })),
  ];

  return allMembers.map((member) => {
    const slug = member.name
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/(^-|-$)+/g, "");
    return {
      params: { name: slug },
      props: { member },
    };
  });
}

const { member } = Astro.props;

// Build GitHub URL if not full url
const githubUrl = member.github?.startsWith("http")
  ? member.github
  : `https://github.com/${member.username}`;
const linkedinUrl = member.linkedin;

// Color schemes matching Google developer colors
const accentColors: Record<
  string,
  { border: string; text: string; bg: string; dot: string }
> = {
  blue: {
    border: "border-blue-500/20 dark:border-blue-400/30",
    text: "text-blue-500 dark:text-blue-400",
    bg: "bg-blue-500/10 dark:bg-blue-400/10",
    dot: "bg-blue-500",
  },
  red: {
    border: "border-red-500/20 dark:border-red-400/30",
    text: "text-red-500 dark:text-red-400",
    bg: "bg-red-500/10 dark:bg-red-400/10",
    dot: "bg-red-500",
  },
  yellow: {
    border: "border-yellow-500/20 dark:border-yellow-400/30",
    text: "text-[#FBBC04] dark:text-yellow-400",
    bg: "bg-yellow-500/10 dark:bg-yellow-400/10",
    dot: "bg-[#FBBC04]",
  },
  green: {
    border: "border-green-500/20 dark:border-green-400/30",
    text: "text-green-500 dark:text-green-400",
    bg: "bg-green-500/10 dark:bg-green-400/10",
    dot: "bg-green-500",
  },
};

const activeAccent = accentColors[member.color] || accentColors.blue;
---

<Layout>
  <Header />

  <main
    class="w-full min-h-screen py-24 px-6 md:px-12 lg:px-24 font-sans text-gray-900 dark:text-white bg-white dark:bg-[#0B0D17] relative overflow-hidden -mt-[3rem] pt-[10rem]"
  >
    <!-- Dynamic Background Elements -->
    <div
      class="absolute top-0 right-0 w-96 h-96 bg-blue-500/5 dark:bg-blue-600/10 blur-[120px] rounded-full -translate-y-1/2 translate-x-1/2 select-none pointer-events-none"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-96 h-96 bg-green-500/5 dark:bg-blue-500/10 blur-[120px] rounded-full translate-y-1/2 -translate-x-1/2 select-none pointer-events-none"
    >
    </div>

    <div class="max-w-6xl mx-auto relative z-10">
      <!-- Back Button -->
      <div class="mb-10">
        <a
          href="/team"
          class="inline-flex items-center gap-2 text-sm font-semibold text-gray-500 dark:text-gray-400 hover:text-blue-500 dark:hover:text-blue-400 transition-colors group cursor-pointer"
        >
          <ChevronLeft
            size={16}
            class="transition-transform group-hover:-translate-x-1"
          />
          <span>Back to Team</span>
        </a>
      </div>

      <!-- Main Layout Grid -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
        <!-- LEFT SIDEBAR: Basic Profile Info (col-span-4) -->
        <section
          class="md:col-span-4 flex flex-col items-center md:items-start text-center md:text-left"
        >
          <!-- Avatar -->
          <div
            class={`w-40 h-40 md:w-56 md:h-56 rounded-full overflow-hidden border-4 shadow-lg shrink-0 transition-transform duration-500 hover:scale-105 ${activeAccent.border}`}
          >
            <Image
              src={member.image}
              alt={member.name}
              class="w-full h-full object-cover"
              width={350}
              height={350}
            />
          </div>

          <!-- Name & Username -->
          <h1
            class="text-3xl md:text-4xl font-bold mt-6 text-gray-900 dark:text-white leading-tight"
          >
            {member.name}
          </h1>

          <!-- Role Badges -->
          <div class="mt-3 flex flex-wrap gap-2">
            <span
              class={`text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full ${activeAccent.bg} ${activeAccent.text}`}
            >
              {member.role}
            </span>
          </div>

          <!-- Bio / Status Box -->
          <div
            class="w-full mt-5 p-4 bg-gray-50 dark:bg-[#1A1D2B] border border-gray-200/60 dark:border-white/5 rounded-2xl text-sm text-gray-600 dark:text-gray-300 relative group/status"
          >
            <div
              class="absolute -top-2 px-2 bg-white dark:bg-[#0B0D17] text-[9px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest select-none"
            >
              Status
            </div>
            <p class="italic leading-relaxed">"{member.bio}"</p>
          </div>

          <!-- Metadata List -->
          <div
            class="w-full mt-6 space-y-3.5 border-t border-gray-150 dark:border-white/5 pt-6 text-sm text-gray-600 dark:text-gray-300"
          >
            <div class="flex items-center gap-3">
              <Building2
                size={16}
                class="text-gray-400 dark:text-gray-500 shrink-0"
              />
              <span class="truncate">{member.company}</span>
            </div>
            <div class="flex items-center gap-3">
              <MapPin
                size={16}
                class="text-gray-400 dark:text-gray-500 shrink-0"
              />
              <span>{member.location}</span>
            </div>
            <div class="flex items-center gap-3">
              <Mail
                size={16}
                class="text-gray-400 dark:text-gray-500 shrink-0"
              />
              <a
                href={`mailto:${member.email}`}
                class="text-blue-600 dark:text-blue-400 hover:underline truncate"
                >{member.email}</a
              >
            </div>
            {
              member.website && (
                <div class="flex items-center gap-3">
                  <Link2
                    size={16}
                    class="text-gray-400 dark:text-gray-500 shrink-0"
                  />
                  <a
                    href={member.website}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-blue-600 dark:text-blue-400 hover:underline truncate"
                  >
                    {member.website.replace(/^https?:\/\/(www\.)?/, "")}
                  </a>
                </div>
              )
            }
          </div>

          <!-- Social Shortcuts -->
          <div
            class="flex flex-wrap gap-3 mt-6 w-full justify-center md:justify-start"
          >
            {
              linkedinUrl && (
                <a
                  href={linkedinUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 px-4 py-2 border border-gray-200 dark:border-white/5 rounded-full text-xs font-semibold text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-white/5 hover:border-blue-500 dark:hover:border-blue-400 transition-colors shadow-sm cursor-pointer animate-smooth"
                  aria-label="LinkedIn Profile"
                >
                  <Linkedin size={14} class="text-[#0A66C2]" />
                  <span>LinkedIn</span>
                </a>
              )
            }
            {
              githubUrl && (
                <a
                  href={githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 px-4 py-2 border border-gray-200 dark:border-white/5 rounded-full text-xs font-semibold text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-white/5 hover:border-black dark:hover:border-white transition-colors shadow-sm cursor-pointer animate-smooth"
                  aria-label="GitHub Profile"
                >
                  <Github size={14} />
                  <span>GitHub</span>
                </a>
              )
            }
          </div>
        </section>

        <!-- RIGHT CONTENT: README (col-span-8) -->
        <section class="md:col-span-8 flex flex-col">
          <!-- README Box -->
          <div
            class="w-full flex flex-col rounded-2xl overflow-hidden border border-gray-200 dark:border-white/5 shadow-sm"
          >
            <!-- README Header -->
            <div
              class="bg-gray-50 dark:bg-[#111422] border-b border-gray-200 dark:border-white/5 px-4 py-3 flex items-center justify-between text-xs font-mono text-gray-500 dark:text-gray-400 select-none"
            >
              <div class="flex items-center gap-2">
                <FileCode size={14} class="text-gray-400 dark:text-gray-500" />
                <span>{member.username} / INTRO.md</span>
              </div>
              <span
                class="text-[9px] font-bold text-gray-400 bg-gray-100 dark:bg-white/5 px-1.5 py-0.5 rounded"
                >Preview</span
              >
            </div>

            <!-- README Body -->
            <div
              class="bg-white dark:bg-[#1A1D2B] p-6 md:p-8 text-gray-800 dark:text-gray-200 prose prose-sm dark:prose-invert max-w-none"
            >
              <h2
                class="text-xl md:text-2xl font-bold text-gray-900 dark:text-white mb-4 border-b border-gray-200 dark:border-white/5 pb-2 leading-snug"
              >
                {member.readme.title}
              </h2>

              <p
                class="leading-relaxed text-gray-600 dark:text-gray-300 text-sm whitespace-pre-line mb-6 font-sans"
              >
                {member.readme.description}
              </p>

              <!-- Skills / Languages -->
              <h3
                class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-3"
              >
                Programming & Technologies
              </h3>
              <div class="flex flex-wrap gap-2">
                {
                  member.readme.skills.map((skill) => (
                    <span class="text-xs font-medium px-3 py-1 bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/5 text-gray-800 dark:text-gray-200 rounded-lg">
                      {skill}
                    </span>
                  ))
                }
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
