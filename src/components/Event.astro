---
import EventsData from "../content/events.json";
import { Image } from "astro:assets";
import { ChevronRight, ChevronLeft } from "@lucide/astro"

interface Props {
  limit?: number;
  showAllLink?: boolean;
  showMarquee?: boolean;
  isGrid?: boolean;
  initialCount?: number;
}

const { 
  limit, 
  showAllLink = false, 
  showMarquee = true, 
  isGrid = false,
  initialCount = 8
} = Astro.props;

let events = EventsData.map((event) => ({
  title: event.title,
  date: event.date,
  status: event.status.toLowerCase(),
  statusLabel: event.status,
  desc: event.description,
  eventType: event.type,
  image: event.image,
  link: event.link,
}));

// If it's a grid (like on the events page), we might want to handle limits differently
// But if limit is provided, we still slice
if (limit) {
  events = events.slice(0, limit);
}
---

<style>
  @keyframes scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .marquee__track {
    display: flex;
    animation: scroll 20s linear infinite;
    width: fit-content;
  }

  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .event-card-hidden {
    display: none;
  }
</style>

{showMarquee && (
  <div class="bg-white dark:bg-[#0B0D17] font-sans overflow-hidden pt-12">
    <div
      class="w-full sm:text-2xl rotate-1.9 bg-yellow-500 py-6 mb-10 overflow-hidden shadow-lg no-scrollbar"
    >
      <div class="marquee__track no-scrollbar" style="animation-duration: 15s;">
        {
          Array(10)
            .fill("What's Happening In SJEC?")
            .map((text) => (
              <span class="whitespace-nowrap text-xl sm:text-2xl font-semibold uppercase text-white px-4">
                {text}
              </span>
            ))
        }
      </div>
    </div>

    <div
      class="w-full py-6 mb-10 bg-green-600 overflow-hidden shadow-lg no-scrollbar"
      style="transform: rotate(-2deg) translate(12px, -30px); width: 120%; margin-left: -10%;"
    >
      <div class="marquee__track no-scrollbar" style="animation-duration: 15s;">
        {
          Array(10)
            .fill("From Workshops To Hackathons!")
            .map((text) => (
              <span class="whitespace-nowrap text-xl sm:text-2xl font-semibold uppercase text-white px-4 ">
                {text}
              </span>
            ))
        }
      </div>
    </div>
  </div>
)}

  <section id="events" class="py-24 px-6 md:px-12 lg:px-24 font-sans overflow-hidden bg-white dark:bg-[#0B0D17]">
  <div class="max-w-7xl mx-auto">
    <!-- Header Section -->
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-6xl font-bold mb-4 tracking-tight text-gray-900 dark:text-white">
        Event <span class="text-blue-500 dark:text-blue-400">T</span><span class="text-red-500 dark:text-red-400">I</span><span class="text-[#FBBC04] dark:text-yellow-400">M</span><span class="text-green-500 dark:text-green-400">E</span>LINE
      </h2>
      <p class="text-gray-600 dark:text-gray-400 text-lg md:text-xl max-w-2xl mx-auto">
        Explore our journey through workshops, hackathons, and tech talks on campus.
      </p>
    </div>

    <!-- Events Container -->
    <div class="relative group/slider">
      <div 
        id="events-container" 
        class={`${isGrid ? 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8' : 'flex overflow-x-auto snap-x snap-mandatory gap-6 md:gap-8 pb-12 no-scrollbar scroll-smooth px-4 md:px-0 relative z-10'}`}
      >
        {events.map((event, index) => (
          <div 
            class={`${isGrid ? 'flex flex-col' : 'flex-none w-[85%] sm:w-[45%] lg:w-[31%] xl:w-[23%] snap-start md:snap-start flex flex-col'} ${isGrid && index >= initialCount ? 'event-card-hidden' : ''}`}
            data-event-card
          >
            <!-- Event Card -->
            <a 
              href={event.link} 
              target="_blank" 
              rel="noopener noreferrer"
              class="w-full h-[25rem] md:h-[30rem] bg-gray-50 dark:bg-[#1A1D2B] border border-gray-100 dark:border-white/5 rounded-3xl p-8 md:p-10 flex flex-col items-center text-center hover:shadow-xl hover:-translate-y-2 transition-all duration-500 group shadow-sm no-underline"
            >
              
              <!-- Circular Image (Centered) -->
              <div class="w-20 h-20 md:w-24 md:h-24 rounded-full overflow-hidden mb-6 border-4 border-white dark:border-gray-800 shadow-lg shrink-0 mx-auto">
                <Image 
                  src={event.image} 
                  alt={event.title} 
                  class="w-full h-full object-cover"
                  width={200}
                  height={200}
                />
              </div>

              <!-- Event Info -->
              <div class="flex-grow flex flex-col items-center w-full">
                <time class="text-blue-600 dark:text-blue-400 font-bold uppercase tracking-widest text-xs md:text-sm mb-2">
                  {event.date}
                </time>
                <h3 class="text-xl md:text-2xl font-bold text-gray-900 dark:text-white mb-3 leading-tight group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-2">
                  {event.title}
                </h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm line-clamp-4 leading-relaxed">
                  {event.desc}
                </p>
              </div>

              <div class="mt-auto pt-6 flex flex-wrap justify-center gap-2">
                <span class="px-3 py-1 rounded-full text-[0.6rem] font-bold bg-gray-100 dark:bg-gray-800 text-gray-500 uppercase tracking-widest leading-none">
                  {event.eventType}
                </span>
                <span class={`px-3 py-1 rounded-full text-[0.6rem] font-bold uppercase tracking-widest leading-none ${
                  event.status === 'upcoming' ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700'
                }`}>
                  {event.statusLabel}
                </span>
              </div>
            </a>
          </div>
        ))}
        {!isGrid && <div class="flex-none w-px h-full"></div>}
      </div>
    </div>

    {showAllLink && (
      <div class="flex justify-center mt-20">
        <a href="/events" class="group px-6 py-2.5 md:px-8 md:py-3.5 border border-gray-200 dark:border-gray-800 rounded-full text-sm md:text-base font-bold text-gray-900 dark:text-white hover:bg-gray-50 dark:hover:bg-white/5 transition-all duration-300">
          Explore full timeline
        </a>
      </div>
    )}

    {isGrid && events.length > initialCount && (
      <div class="flex justify-center mt-20">
        <button 
          id="load-more-events"
          class="group px-6 py-2.5 md:px-8 md:py-3.5 border border-gray-200 dark:border-gray-800 rounded-full text-sm md:text-base font-bold text-gray-900 dark:text-white hover:bg-gray-50 dark:hover:bg-white/5 transition-all duration-300 hover:cursor-pointer"
        >
          Load more events
        </button>
      </div>
    )}
  </div>  
</section>

<script>
  const loadMoreBtn = document.getElementById('load-more-events');
  const hiddenCards = document.querySelectorAll('.event-card-hidden');
  
  if (loadMoreBtn) {
    let currentlyShown = 8; // Matching initialCount
    const batchSize = 8;

    loadMoreBtn.addEventListener('click', () => {
      const allCards = document.querySelectorAll('[data-event-card]');
      let revealedCount = 0;
      
      allCards.forEach((card, index) => {
        if (index >= currentlyShown && revealedCount < batchSize) {
          card.classList.remove('event-card-hidden');
          revealedCount++;
        }
      });

      currentlyShown += revealedCount;

      if (currentlyShown >= allCards.length) {
        loadMoreBtn.style.display = 'none';
      }
    });
  }
</script>
