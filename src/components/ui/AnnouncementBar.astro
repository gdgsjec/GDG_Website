---
interface Props {
    title: string;
    link: string;
    linkLabel?: string;
}

const { title, link, linkLabel = "Learn more" } = Astro.props;
---

<div
    id="announcement-bar"
    class="fixed top-[5.5rem] left-1/2 -translate-x-1/2 z-40 w-[95%] md:w-[80%] mx-auto pointer-events-none transition-all duration-500 ease-in-out"
>
    <div
        class="bg-blue-500 bg-[url('https://preline.co/assets/svg/examples/abstract-1.svg')] bg-no-repeat bg-cover bg-center p-3 md:p-4 rounded-xl text-center shadow-xl pointer-events-auto border border-white/10 overflow-hidden"
    >
        <div
            class="flex flex-col sm:flex-row justify-center items-center gap-2 md:gap-4"
        >
            <p class="text-xs md:text-sm text-white font-medium leading-tight">
                {title}
            </p>
            <a
                class="shrink-0 py-1 px-3 md:py-1.5 md:px-4 inline-flex items-center gap-x-2 text-[10px] md:text-xs font-bold uppercase tracking-wider rounded-full border border-white/30 text-white bg-white/10 hover:bg-white hover:text-blue-600 backdrop-blur-sm transition-all focus:outline-none"
                href={link}
                target="_blank"
                rel="noopener noreferrer"
            >
                {linkLabel}
                <svg
                    class="shrink-0 size-3 md:size-4"
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
                >
            </a>
        </div>
    </div>
</div>

<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        const bar = document.getElementById("announcement-bar");
        if (!bar) return;

        window.addEventListener("scroll", () => {
            if (window.scrollY > 25) {
                bar.style.opacity = "0";
                bar.style.pointerEvents = "none";
            } else {
                bar.style.opacity = "1";
                bar.style.pointerEvents = "none";
            }
        });
    });
</script>
