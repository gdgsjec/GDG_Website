---
import "../styles/Header.css";
import { Image } from "astro:assets";
---

<div
  class="fixed top-4 left-1/2 -translate-x-1/2 z-50 w-[95%] md:w-[80%] rounded-xl p-[2px] overflow-hidden google-shimmer-bg"
>
  <div
    class="absolute inset-0 google-shimmer-glow opacity-30 blur-md pointer-events-none"
  >
  </div>

  <header
    class="w-full rounded-[10px] backdrop-blur-lg bg-white/80 dark:bg-black/80 border border-black/10 dark:border-white/20"
  >
    <div class="flex items-center justify-between px-6 py-3">
      <a href="/" class="flex items-center">
        <Image
          src="/images/GDG_LOGO.webp"
          alt="GDG Logo"
          class="h-5 md:h-6 w-auto transition-all"
          width={100}
          height={100}
          fetchpriority="high"
        />
      </a>

      <nav
        class="hidden md:flex items-center space-x-6 font-bold uppercase text-xs tracking-wider text-[#3C3C43] dark:text-[#F2F4F7]"
      >
        <a href="/blog" class="text-md corner-link">Blog</a>
        <a href="/team" class="text-md corner-link">Team</a>
        <a href="/events" class="text-md corner-link">Events</a>
        <a href="/projects" class="text-md corner-link">Projects</a>
      </nav>

      <div class="hidden md:flex">
        <button
          id="theme-toggle"
          class="group relative w-16 h-8 rounded-full bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 backdrop-blur-xl transition-all duration-500 flex items-center p-1 overflow-hidden"
          aria-label="Toggle theme"
        >
          <div
            class="relative z-10 flex w-full justify-between items-center px-1.5 pointer-events-none"
          >
            <div
              class="text-gray-400 group-hover:text-yellow-500 transition-colors"
            >
              <svg
                class="w-3.5 h-3.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2.5"
                  d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
                ></path>
              </svg>
            </div>

            <div
              class="text-gray-400 group-hover:text-blue-400 transition-colors"
            >
              <svg
                class="w-3.5 h-3.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2.5"
                  d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
                ></path>
              </svg>
            </div>
          </div>

          <div
            id="theme-indicator"
            class="absolute left-1 w-6 h-6 rounded-full bg-white shadow-[0_2px_10px_rgba(0,0,0,0.1)] transition-transform duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)]"
          >
          </div>
        </button>
      </div>

      <button
        id="menu-btn"
        class="md:hidden flex flex-col items-center justify-center w-8 h-8 relative text-black dark:text-white"
      >
        <span id="hamburger-line-1" class="w-6 h-0.5 bg-current absolute"
        ></span>
        <span id="hamburger-line-2" class="w-6 h-0.5 bg-current"></span>
        <span id="hamburger-line-3" class="w-6 h-0.5 bg-current absolute"
        ></span>
      </button>
    </div>
  </header>
</div>

<nav
  id="mobile-menu"
  class="fixed md:hidden top-[6.5rem] w-[95%] max-w-md rounded-xl
  bg-white/30 dark:bg-black/30 backdrop-blur-md
  dark:text-white font-bold shadow-2xl border border-black/10 dark:border-white/20
  p-6 space-y-6 opacity-0 pointer-events-none transition-all duration-300 ease-out z-50"
  style="left: 50%; transform: translateX(-50%) translateY(-1rem);"
>
  <a href="/blog" class="corner-link w-full text-center block py-2">Blog</a>
  <a href="/team" class="corner-link w-full text-center block py-2">Team</a>
  <a href="/events" class="corner-link w-full text-center block py-2">Events</a>
  <a href="/projects" class="corner-link w-full text-center block py-2"
    >Projects</a
  >
</nav>

<style>
  .google-shimmer-bg {
    position: fixed;
  }

  .google-shimmer-bg::before,
  .google-shimmer-glow {
    content: "";
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: conic-gradient(
      from 0deg,
      #4285f4 0deg 90deg,
      #ea4335 90deg 180deg,
      #fbbc05 180deg 270deg,
      #34a853 270deg 360deg
    );
    animation: rotateShimmer 6s linear infinite;
    z-index: -1;
  }

  @keyframes rotateShimmer {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  #hamburger-line-1 {
    transform: translateY(-0.5rem);
    transition: all 0.3s;
  }

  #hamburger-line-2 {
    transition: all 0.3s;
  }

  #hamburger-line-3 {
    transform: translateY(0.5rem);
    transition: all 0.3s;
  }

  #menu-btn.active #hamburger-line-1 {
    transform: translateY(0) rotate(45deg);
  }

  #menu-btn.active #hamburger-line-2 {
    opacity: 0;
  }

  #menu-btn.active #hamburger-line-3 {
    transform: translateY(0) rotate(-45deg);
  }

  #mobile-menu.menu-open {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .google-shimmer-bg::before,
    .google-shimmer-glow {
      animation: none;
    }
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");

    btn.addEventListener("click", () => {
      mobileMenu.classList.toggle("menu-open");
      btn.classList.toggle("active");
    });

    document.addEventListener("click", (e) => {
      if (!mobileMenu.contains(e.target) && !btn.contains(e.target)) {
        mobileMenu.classList.remove("menu-open");
        btn.classList.remove("active");
      }
    });
  });
</script>
