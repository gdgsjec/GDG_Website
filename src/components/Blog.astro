---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { ChevronLeft, ChevronRight } from "@lucide/astro";

const blogs = await getCollection("blog");
const sortedBlogs = blogs.sort(
  (a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<section
  id="blogs-section"
  class="bg-white dark:bg-[#0B0D17] py-24 px-6 md:px-12 lg:px-24 font-sans overflow-hidden"
>
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-8">
      <div class="max-w-2xl">
        <h2 class="text-4xl md:text-7xl font-bold text-gray-900 dark:text-white mb-6 leading-tight tracking-tight">
          Insights & <br class="hidden md:block" /> stories from our club
        </h2>
        <p class="text-gray-600 dark:text-gray-400 text-lg">
          Read about our latest experiences, technical deep-dives, and community updates.
        </p>
      </div>

      <!-- Navigation Arrows -->
      <div class="flex items-center gap-4">
        <button
          id="prev-blog"
          aria-label="Previous blog"
          class="p-4 border border-gray-200 dark:border-gray-800 rounded-full text-gray-500 hover:text-black dark:hover:text-white hover:border-black dark:hover:border-white transition-all duration-300 focus:outline-none"
        >
          <ChevronLeft size={24} />
        </button>
        <button
          id="next-blog"
          aria-label="Next blog"
          class="p-4 border border-gray-200 dark:border-gray-800 rounded-full text-gray-500 hover:text-black dark:hover:text-white hover:border-black dark:hover:border-white transition-all duration-300 focus:outline-none"
        >
          <ChevronRight size={24} />
        </button>
      </div>
    </div>

    <!-- Blog Container with Horizontal Scroll -->
    <div
      id="blog-slider"
      class="flex overflow-x-auto snap-x snap-mandatory gap-8 pb-12 no-scrollbar scroll-smooth"
    >
      {
        sortedBlogs.map((blog: any) => (
          <a 
            href={`/blog/${blog.slug}`}
            class="group flex-none w-[85%] sm:w-[45%] lg:w-[35%] snap-start flex flex-col"
          >
            <!-- Featured Image -->
            <div class="relative aspect-[4/5] w-full mb-8 overflow-hidden rounded-[2.5rem] bg-gray-100 dark:bg-gray-800/50 shadow-sm transition-all duration-500 group-hover:shadow-2xl group-hover:-translate-y-2">
              <Image
                src={blog.data.image}
                alt={blog.data.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
                width={800}
                height={1000}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
              
              <div class="absolute bottom-8 left-8 right-8 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
                <span class="inline-flex items-center gap-2 text-white font-bold">
                  Read Article <ChevronRight size={16} />
                </span>
              </div>
            </div>

            <!-- Blog Info -->
            <div class="flex flex-col">
              <div class="flex items-center gap-3 text-[10px] font-bold uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400 mb-4">
                <span>{blog.data.category}</span>
                <span class="w-1 h-1 bg-gray-300 dark:bg-gray-700 rounded-full" />
                <span>
                  {new Date(blog.data.pubDate).toLocaleDateString("en-US", {
                    month: "short",
                    year: "numeric",
                  })}
                </span>
              </div>
              
              <h3 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white leading-tight group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors duration-300 tracking-tight">
                {blog.data.title}
              </h3>
            </div>
          </a>
        ))
      }
    </div>

    <!-- View All Button -->
    <div class="flex justify-center mt-8">
      <a
        href="/blog"
        class="group inline-flex items-center gap-3 px-8 py-4 border border-gray-200 dark:border-gray-800 rounded-full text-base font-bold text-gray-900 dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all duration-300"
      >
        Explore all blogs
        <ChevronRight size={20} class="transition-transform group-hover:translate-x-1" />
      </a>
    </div>
  </div>
</section>

<script>
  const slider = document.getElementById("blog-slider");
  const nextBtn = document.getElementById("next-blog");
  const prevBtn = document.getElementById("prev-blog");

  if (slider && nextBtn && prevBtn) {
    nextBtn.addEventListener("click", () => {
      const cardWidth = slider.querySelector("a")?.clientWidth || 300;
      slider.scrollBy({ left: cardWidth + 32, behavior: "smooth" });
    });

    prevBtn.addEventListener("click", () => {
      const cardWidth = slider.querySelector("a")?.clientWidth || 300;
      slider.scrollBy({ left: -(cardWidth + 32), behavior: 'smooth' });
    });
  }
</script>

<style>

  /* Hide scrollbar for Chrome, Safari and Opera */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }

  /* Hide scrollbar for IE, Edge and Firefox */
  .no-scrollbar {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }
</style>
